{
  "hosting": {
    "site": "quill-platform",
    "public": "firebase-public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "quill-web",
          "region": "us-central1"
        }
      }
    ]
  }
}
