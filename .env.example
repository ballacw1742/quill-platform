# Quill Platform — environment template
# Copy to .env and fill in. Never commit .env.

# Database — async URL for runtime, sync URL for alembic
DATABASE_URL=postgresql+asyncpg://quill:quill@localhost:5432/quill
DATABASE_URL_SYNC=postgresql+psycopg2://quill:quill@localhost:5432/quill

# For local-only quick start without Postgres, set:
# DATABASE_URL=sqlite+aiosqlite:///./quill_dev.db
# DATABASE_URL_SYNC=sqlite:///./quill_dev.db

# JWT signing key (Sprint 1 dev sessions). Replace in prod.
SECRET_KEY=dev-secret-change-me-in-production

# Shared secret for service-account agent auth (Sprint 1).
AGENT_SHARED_SECRET=dev-agent-secret-change-me

# Sentry DSN (leave blank to disable)
SENTRY_DSN=

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional: log level
LOG_LEVEL=INFO

# Optional: Telegram chat for SLA breach notifications (Sprint 1 stub)
TELEGRAM_NOTIFY_CHAT_ID=

# ---------------------------------------------------------------------------
# WebAuthn / passkey config (Sprint 2.2)
# ---------------------------------------------------------------------------
# RP ID is the apex domain the passkey is bound to (no scheme, no port).
# Use "localhost" in dev. In prod set to e.g. "quill.example.com".
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Quill
# Origin is the full https://host[:port] the browser sees. Comma-separate
# extras via WEBAUTHN_EXTRA_ORIGINS (e.g. ngrok tunnels in dev).
WEBAUTHN_ORIGIN=http://localhost:3000
WEBAUTHN_EXTRA_ORIGINS=

# Separate signing key for the short-lived approval action assertion JWT
# (NOT the same as SECRET_KEY — rotate independently).
ACTION_ASSERTION_SECRET=dev-action-assertion-change-me
# Lifetime of the action assertion. 60s gives the user one biometric tap and
# one decision; replay-protected by jti consumption.
ACTION_ASSERTION_TTL_SECONDS=60

# Length of a normal user session (passkey-issued JWT).
SESSION_TTL_HOURS=4

# Allow email/password as a fallback. Set to "false" in production.
DEV_AUTH_FALLBACK=true

# ---------------------------------------------------------------------------
# Audit log resilience (Sprint 2.3)
# ---------------------------------------------------------------------------
# Backblaze B2 mirror credentials. Leave blank to fall back to local-disk mode
# (writes to AUDIT_MIRROR_LOCAL_PATH). In prod, set Object Lock = compliance,
# retention = B2_OBJECT_LOCK_YEARS years on the bucket.
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=quill-audit
B2_OBJECT_LOCK_YEARS=7

# Local-mode mirror dir (used when B2 creds absent).
AUDIT_MIRROR_LOCAL_PATH=./_local_audit_mirror

# Mirror retry policy + drain interval.
AUDIT_MIRROR_MAX_RETRIES=5
AUDIT_MIRROR_DRAIN_INTERVAL_SECONDS=2.0

# Nightly verification schedule (informational — actual cron is set in the OS).
AUDIT_VERIFY_SCHEDULE_CRON=0 2 * * *

# Touch-file feature flag — presence of this file freezes audit writes
# (set automatically by audit_verify_run.py on a non-OK result).
AUDIT_FREEZE_FLAG_PATH=./_audit_freeze.flag

# ---------------------------------------------------------------------------
# Web (Next.js) — these go in web/.env.local
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_USE_MOCK=0
# NEXT_PUBLIC_DEV_AUTH_FALLBACK=1   # show the email/password panel on /login

# ---------------------------------------------------------------------------
# Sprint 2.4 — Telegram bot + Sentry (multi-service) + 7am ops digest
# ---------------------------------------------------------------------------
# Telegram bot (long-poll dev). Get token from @BotFather.
TELEGRAM_BOT_TOKEN=
# HMAC secret for `/start <code>` pairing. Rotate independently of SECRET_KEY.
TELEGRAM_PAIRING_SECRET=dev-pairing-secret-change-me
# HMAC secret for ephemeral deep-links to the web UI's passkey ceremony.
# Defaults to ACTION_ASSERTION_SECRET if unset (aligns deep-link TTL with
# action assertion TTL — both should be ~60s).
DEEPLINK_SIGNING_SECRET=
DEEPLINK_TTL_SECONDS=60

# Charles's Telegram chat_id (target for Daily Brief + reminders + alerts).
# Populated automatically when /start <code> succeeds; setting here is optional.
DAILY_BRIEF_CHAT_ID=

# Per-service Sentry DSNs. SENTRY_DSN is the legacy (Sprint 1.1) catch-all.
SENTRY_DSN_API=
SENTRY_DSN_RUNTIME=
SENTRY_DSN_BOT=

# Deployment environment tag (Sentry/log labels). dev | staging | prod.
ENVIRONMENT=dev

# QUILL_WEB_BASE_URL — used by the bot for deep links. Defaults to
# http://localhost:3000 in dev.
QUILL_WEB_BASE_URL=http://localhost:3000
